<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - {{PROJECT_NAME}}</title>
    {{USE_TAILWIND}}
    <script src="https://cdn.tailwindcss.com"></script>
    {{/USE_TAILWIND}}
    {{USE_BOOTSTRAP}}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    {{/USE_BOOTSTRAP}}
</head>
<body class="{{USE_TAILWIND}}bg-gray-100 h-screen flex items-center justify-center{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}bg-light d-flex align-items-center vh-100{{/USE_BOOTSTRAP}}">
    
    <div class="{{USE_TAILWIND}}w-full max-w-md bg-white p-8 rounded-lg shadow-md{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}container d-flex justify-center{{/USE_BOOTSTRAP}}">
        <div class="{{USE_BOOTSTRAP}}card shadow-sm w-100" style="max-width: 400px; margin: auto;{{/USE_BOOTSTRAP}}">
            <div class="{{USE_BOOTSTRAP}}card-body p-4{{/USE_BOOTSTRAP}}">
                <h2 class="{{USE_TAILWIND}text-2xl font-bold mb-6 text-center{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}h3 mb-4 text-center{{/USE_BOOTSTRAP}}">
                    Create Account
                </h2>

                <?php if (isset($_SESSION['error'])): ?>
                    <div class="{{USE_TAILWIND}}bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4 text-sm{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}alert alert-danger py-2 small mb-3{{/USE_BOOTSTRAP}}">
                        <?= $_SESSION['error']; unset($_SESSION['error']); ?>
                    </div>
                <?php endif; ?>

                <form action="/form/store" method="POST" class="{{USE_TAILWIND}}space-y-4{{/USE_TAILWIND}}">
                    <div>
                        <label class="{{USE_TAILWIND}}block text-sm font-medium text-gray-700{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}form-label{{/USE_BOOTSTRAP}}">Full Name</label>
                        <input type="text" name="name" required class="{{USE_TAILWIND}}mt-1 block w-full border rounded-md p-2 shadow-sm{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}form-control{{/USE_BOOTSTRAP}}">
                    </div>
                    <div>
                        <label class="{{USE_TAILWIND}}block text-sm font-medium text-gray-700{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}form-label{{/USE_BOOTSTRAP}}">Email</label>
                        <input type="email" name="email" required class="{{USE_TAILWIND}}mt-1 block w-full border rounded-md p-2 shadow-sm{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}form-control{{/USE_BOOTSTRAP}}">
                    </div>
                    <div>
                        <label class="{{USE_TAILWIND}}block text-sm font-medium text-gray-700{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}form-label{{/USE_BOOTSTRAP}}">Password</label>
                        <input type="password" name="password" required class="{{USE_TAILWIND}}mt-1 block w-full border rounded-md p-2 shadow-sm{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}form-control{{/USE_BOOTSTRAP}}">
                    </div>
                    <button type="submit" class="{{USE_TAILWIND}}w-full bg-blue-600 text-white p-2 rounded-md hover:bg-blue-700 mt-4{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}btn btn-primary w-full mt-3{{/USE_BOOTSTRAP}}">
                        Register
                    </button>
                </form>

                <p class="{{USE_TAILWIND}}mt-6 text-center text-sm text-gray-600{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}text-center mt-4 small{{/USE_BOOTSTRAP}}">
                    Already have an account? 
                    <a href="/form/login" class="{{USE_TAILWIND}}text-blue-600 hover:underline{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}text-primary{{/USE_BOOTSTRAP}}">Login here</a>
                </p>
            </div>
        </div>
    </div>

</body>
</html>
