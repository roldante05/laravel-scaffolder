<body class="{{USE_TAILWIND}}bg-slate-50 text-slate-900 antialiased flex items-center justify-center min-h-screen px-4{{/USE_TAILWIND}}">
    <div class="{{USE_TAILWIND}}max-w-md w-full bg-white p-10 rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}container mt-5{{/USE_BOOTSTRAP}}">
        <div class="text-center mb-10">
            <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg shadow-indigo-200">
