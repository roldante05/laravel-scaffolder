        <?php endif; ?>

        <form action="/login" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Correo Electrónico</label>
                <input type="email" name="email" 
                    class="{{USE_TAILWIND}}w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:bg-white focus:outline-none transition-all{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}form-control{{/USE_BOOTSTRAP}}" 
                    placeholder="nombre@ejemplo.com" required>
            </div>
            <div>
                <div class="flex justify-between mb-2">
                    <label class="block text-sm font-bold text-slate-700">Contraseña</label>
                    <a href="#" class="text-xs font-bold text-indigo-600 hover:underline">¿Olvidaste tu contraseña?</a>
                </div>
                <input type="password" name="password" 
                    class="{{USE_TAILWIND}}w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:bg-white focus:outline-none transition-all{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}form-control{{/USE_BOOTSTRAP}}" 
                    placeholder="••••••••" required>
            </div>
            <button type="submit" 
                class="{{USE_TAILWIND}}w-full bg-indigo-600 text-white py-4 rounded-xl font-bold shadow-lg shadow-indigo-100 hover:bg-indigo-700 hover:-translate-y-0.5 transition-all duration-200{{/USE_TAILWIND}}{{USE_BOOTSTRAP}}btn btn-primary w-100{{/USE_BOOTSTRAP}}">
                Entrar al Panel
            </button>
        </form>
        <p class="mt-8 text-center text-sm text-slate-500">
            ¿No tienes una cuenta? <a href="/register" class="text-indigo-600 font-bold hover:underline">Crea una ahora</a>
