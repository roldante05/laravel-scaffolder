            </p>
            <pre class="bg-gray-900 border border-gray-800 rounded-xl p-6 overflow-x-auto text-sm text-gray-300 leading-7"><code>&lt;?php

namespace App\Controllers;

use App\Core\Controller;
use App\Core\Auth;

class HomeController extends Controller
{
    public function index(): void
    {
        $this->render("welcome", [
            "title" => "Welcome"
        ]);
    }

    public function home(): void
    {
        Auth::requireAuth();
        $this->render("home", [
            "user" => Auth::user()["name"]
        ]);
    }
}</code></pre>
