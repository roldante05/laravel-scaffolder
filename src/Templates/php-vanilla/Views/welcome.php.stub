$deleted = User::delete(1);</code></pre>
            <p class="text-gray-400 leading-relaxed mt-4">
                Los modelos extienden <code class="text-indigo-400">ORM</code> y heredan toda la funcionalidad 
                de base de datos automáticamente.
            </p>
        </section>

        <section class="mb-12 scroll-mt-24" id="migraciones">
            <h2 class="text-2xl font-bold text-white mb-4">Migraciones</h2>
            <p class="text-gray-400 leading-relaxed mb-4">
                Las migraciones se definen como clases PHP en <code class="text-indigo-400">migrations/</code>. 
                Cada migración tiene métodos <code class="text-gray-300">up()</code> y <code class="text-gray-300">down()</code>:
            </p>
            <pre class="bg-gray-900 border border-gray-800 rounded-xl p-6 overflow-x-auto text-sm text-gray-300 leading-7"><code>&lt;?php

return [
    "up" => function (PDO \$db) {
        \$db->exec("CREATE TABLE users (
            id INTEGER PRIMARY KEY AUTO_INCREMENT,
            name VARCHAR(100) NOT NULL,
            email VARCHAR(255) NOT NULL UNIQUE,
            password VARCHAR(255) NOT NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )");
    },
    "down" => function (PDO \$db) {
        \$db->exec("DROP TABLE IF EXISTS users");
    },
];</code></pre>
        </section>

        <section class="mb-8 scroll-mt-24" id="autenticacion">
            <h2 class="text-2xl font-bold text-white mb-4">Autenticación y Seguridad</h2>
            <p class="text-gray-400 leading-relaxed mb-4">
                El sistema de auth usa sesiones seguras con <span class="text-gray-300 font-semibold">Argon2id</span> 
                para hashing de contraseñas, regeneración de ID de sesión tras login, y protección CSRF en todos 
                los formularios.
            </p>
            <p class="text-gray-400 leading-relaxed mb-4">
                Los helpers de seguridad incluyen:
            </p>
            <ul class="list-disc list-inside text-gray-400 space-y-2 mb-6">
                <li><span class="text-gray-300">CSRF</span> — tokens por sesión para prevenir ataques</li>
                <li><span class="text-gray-300">XSS</span> — escape automático en todas las vistas via <code class="text-indigo-400">SecurityHelper::escapeHtml()</code></li>
                <li><span class="text-gray-300">Headers HTTP</span> — Content-Security-Policy, X-Frame-Options, HSTS</li>
                <li><span class="text-gray-300">URL validation</span> — previene open redirects en <code class="text-indigo-400">redirect()</code></li>
            </ul>
            <pre class="bg-gray-900 border border-gray-800 rounded-xl p-6 overflow-x-auto text-sm text-gray-300 leading-7"><code>// Autenticación
\$user = Auth::attempt("email@ejemplo.com", "password123");
Auth::register(["name" => "...", "email" => "...", "password" => "..."]);
Auth::logout();

// Verificación
if (Auth::check()) { /* ... */ }
\$user = Auth::user(); // ["id" => 1, "name" => "...", "email" => "..."]</code></pre>
        </section>
