<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><?= $title ?> - {{PROJECT_NAME}}</title>
    {{USE_TAILWIND}}
    <script src="https://cdn.tailwindcss.com"></script>
    {{/USE_TAILWIND}}
</head>
<body class="{{USE_TAILWIND}}bg-slate-100 text-slate-900 antialiased{{/USE_TAILWIND}}">
    
    <div class="{{USE_TAILWIND}}min-h-screen flex{{/USE_TAILWIND}}">
        <?php if (isset($_SESSION['user_id'])): ?>
            <?php require_once __DIR__ . '/layout/sidebar.php'; ?>
        <?php endif; ?>

        <div class="{{USE_TAILWIND}}flex-1 flex flex-col{{/USE_TAILWIND}}">
            <?php if (isset($_SESSION['user_id'])): ?>
                <?php require_once __DIR__ . '/layout/header.php'; ?>
            <?php else: ?>
                <?php require_once __DIR__ . '/nav.php'; ?>
            <?php endif; ?>

            <main class="{{USE_TAILWIND}}p-8{{/USE_TAILWIND}}">
                <div class="bg-white p-10 rounded-3xl shadow-sm border border-slate-100 max-w-xl mx-auto">
                    <h1 class="text-4xl font-extrabold text-slate-900 mb-2 tracking-tight"><?= $title ?></h1>
                    <p class="text-slate-500 mb-8">¿Tienes alguna duda? Escríbenos.</p>
                    
                    <form class="space-y-6">
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Nombre</label>
                            <input type="text" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2">Mensaje</label>
                            <textarea rows="4" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none transition-all"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-indigo-600 text-white py-4 rounded-xl font-bold shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all">Enviar Mensaje</button>
                    </form>
                </div>
            </main>
        </div>
    </div>
</body>
</html>
